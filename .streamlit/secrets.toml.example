# ============================================================================
# Template secrets — COPY file này thành `secrets.toml` và điền giá trị thật
# .gitignore sẽ chặn `secrets.toml` không cho commit lên git
#
# Với Streamlit Cloud: KHÔNG upload file này. Vào app settings → Secrets
# và paste nội dung như dưới.
# ============================================================================

# Connection string Supabase — copy từ Supabase Dashboard → Settings → Database
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DBNAME]
SUPABASE_DB_URI = "postgresql://postgres.xxx:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"
