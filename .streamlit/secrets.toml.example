# ============================================================================
# Template secrets — COPY file này thành `secrets.toml` và điền giá trị thật
# .gitignore sẽ chặn `secrets.toml` không cho commit lên git
#
# Với Streamlit Cloud: KHÔNG upload file này. Vào app settings → Secrets
# và paste nội dung như dưới.
# ============================================================================

# Connection string Supabase (fallback khi chưa có parquet)
# Format: postgresql://[USER].[PROJECT_REF]:[PASSWORD]@[HOST]:[PORT]/[DBNAME]
SUPABASE_DB_URI = "postgresql://postgres.xxx:PASSWORD@aws-1-ap-south-1.pooler.supabase.com:6543/postgres"

# GitHub Personal Access Token (PAT) — dùng để tải serving.parquet từ GitHub Release
# Tạo tại: https://github.com/settings/tokens → Fine-grained → repo contents:read
GITHUB_TOKEN = "github_pat_xxxx"

# ============================================================================
# AUTH — Phase 2: Role-based authentication
# ============================================================================
# Generate password hash: python scripts/generate_password_hash.py
# 3 roles: admin (all pages + full PII), head (most pages + masked PII), sale (basic pages + no PII)

[auth]
session_timeout = 1800  # seconds (30 min)

[auth.users.admin1]
password_hash = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role = "admin"
display_name = "Admin"

[auth.users.headsale1]
password_hash = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role = "head"
display_name = "Head Sale 1"

[auth.users.sale1]
password_hash = "$2b$12$REPLACE_WITH_BCRYPT_HASH"
role = "sale"
display_name = "Sale 1"

# ============================================================================
# LEGACY AUTH (backward compatible — dùng nếu chưa setup [auth] ở trên)
# ============================================================================
# admin_password = "CHANGE_ME_admin_2026"
#
# [passwords]
# home      = "CHANGE_ME_1"
# kenh      = "CHANGE_ME_2"
# sales     = "CHANGE_ME_3"
# time      = "CHANGE_ME_4"
# export    = "CHANGE_ME_5"
# headsale  = "CHANGE_ME_6"
# executive = "CHANGE_ME_7"
# customer  = "CHANGE_ME_8"
# forecast  = "CHANGE_ME_9"
# kpi       = "CHANGE_ME_10"
